# Copy to .env locally (never commit real secrets)
CLIENT_ID_BDB=
CLIENT_SECRET_BDB=
CODEX_API_KEY=

# Default: openai_api (App Runner Python). Use codex_cli only with Docker + npm @openai/codex
# ROUTER_MODE=openai_api

# Set true locally or briefly on App Runner to return exception + traceback in JSON (disable in prod)
# EXPOSE_ERROR_DETAILS=true

# Corporate SSL inspection (Zscaler, etc.): CERTIFICATE_VERIFY_FAILED — use ONE of:
# HTTP_SSL_VERIFY=false
# SSL_CA_BUNDLE=C:\path\to\corp-and-public-cas.pem

# Optional
# MCP_BASE_URL=https://scripts.cisco.com/api/v2/mcp/namespace/wxcc_mcp_2
# ORG_ID=
# USER_EMAIL=
# CODEX_EXEC_TIMEOUT_SEC=600
# ROUTER_MODEL=gpt-4o-mini
# ASSISTANT_FOLLOWUP=true
