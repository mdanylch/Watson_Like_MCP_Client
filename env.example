# Copy to .env locally (never commit real secrets)
CLIENT_ID_BDB=
CLIENT_SECRET_BDB=
CODEX_API_KEY=

# Set true locally or briefly in prod to return exception + traceback in JSON (disable when untrusted)
# EXPOSE_ERROR_DETAILS=true

# Include stderr, stdout tail, hints, mcp_tool_summaries in /invoke JSON (no secrets; prompt not echoed)
# INVOKE_VERBOSE_DIAGNOSTICS=true

# Corporate SSL inspection (Zscaler, etc.): CERTIFICATE_VERIFY_FAILED — use ONE of:
# HTTP_SSL_VERIFY=false
# SSL_CA_BUNDLE=C:\path\to\corp-and-public-cas.pem

# Optional — streamable HTTP timeouts (seconds), written into Codex config.toml
# MCP_STARTUP_TIMEOUT_SEC=45
# MCP_TOOL_TIMEOUT_SEC=120

# Optional
# MCP_BASE_URL=https://scripts.cisco.com/api/v2/mcp/namespace/wxcc_mcp_2
# ORG_ID=
# USER_EMAIL=
# CODEX_EXEC_TIMEOUT_SEC=600
# Optional: extra `codex exec` flags, space-separated ON ONE LINE (do not repeat CODEX_EXEC_EXTRA_ARGS).
# Run `codex exec --help` — many builds do NOT support `--ask-for-approval` (use `--full-auto` only).
# See https://developers.openai.com/codex/noninteractive/
# CODEX_EXEC_EXTRA_ARGS=--full-auto
# CODEX_BINARY=codex
# CODEX_MCP_SERVER_NAME=bdb_wxcc
